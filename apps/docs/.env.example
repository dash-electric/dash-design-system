# ─── Dash Design System — environment variables ─────────────────────────────
# Copy to .env.local and fill values. DO NOT commit .env.local.

# ─── Registry Bearer auth (REQUIRED in production) ───────────────────────────
# Set on Vercel + locally. PE Dash consumers also set this in their repo's
# .env.local (paste from 1Password / Vault — quarterly rotation).
#
# If left UNSET in local dev (NODE_ENV !== "production"), the API + /r/* gate
# bypasses auth so localhost iteration stays frictionless. In production the
# token is REQUIRED — missing token = all requests return 401.
DASH_REGISTRY_TOKEN=

# Generate a strong token (one-time):
#   openssl rand -base64 32

# ─── Rate limiting (OPTIONAL — falls back to in-memory) ──────────────────────
# Upstash Redis for cross-replica rate limiting. Without these, the limiter
# uses an in-memory Map (single-process; OK for small Vercel deployments).
#
# Provision a free Upstash Redis database at https://console.upstash.com,
# then paste the REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Telemetry (OPTIONAL) ────────────────────────────────────────────────────
# Sentry DSN — errors from API routes get sent here. Without this, errors
# log to stderr in dev and are silently swallowed in production.
SENTRY_DSN=

# Log drain URL — receives structured registry-audit events as JSON POST.
# Useful for adoption metrics (which PE installs which component when).
LOG_DRAIN_URL=

# ─── Public exposed (NEXT_PUBLIC_) ───────────────────────────────────────────
# Version surfaced by /api/health. Defaults to "0.1.0" if unset.
NEXT_PUBLIC_DASH_DS_VERSION=
