{
  "name": "@dash/registry-schema",
  "version": "0.1.0",
  "description": "Shared registry types + runtime zod schemas across Dash DS repo packages.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod-schemas.d.ts",
      "import": "./dist/zod-schemas.js",
      "default": "./dist/zod-schemas.js"
    }
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:json-schema": "tsx scripts/generate-json-schema.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
