{
  "name": "@dash/registry-schema",
  "version": "0.1.0",
  "description": "Shared registry types + runtime zod schemas across Dash DS repo packages.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./zod": "./src/zod-schemas.ts"
  },
  "files": [
    "src",
    "schemas"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:json-schema": "tsx scripts/generate-json-schema.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.7"
  }
}
