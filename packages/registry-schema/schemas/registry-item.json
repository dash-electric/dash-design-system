{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "registry:ui",
        "registry:component",
        "registry:block",
        "registry:template",
        "registry:page",
        "registry:pattern",
        "registry:hook",
        "registry:lib",
        "registry:file",
        "registry:base",
        "registry:theme"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "registry:ui",
              "registry:component",
              "registry:block",
              "registry:template",
              "registry:page",
              "registry:pattern",
              "registry:hook",
              "registry:lib",
              "registry:file",
              "registry:base",
              "registry:theme"
            ]
          },
          "target": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "type"
        ],
        "additionalProperties": false
      }
    },
    "registryDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "devDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tailwind": {},
    "cssVars": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "css": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "properties": {
        "layer": {
          "anyOf": [
            {
              "type": "number",
              "const": 0
            },
            {
              "type": "number",
              "const": 1
            },
            {
              "type": "number",
              "const": 2
            },
            {
              "type": "number",
              "const": 3
            }
          ]
        },
        "theme": {
          "type": "string"
        },
        "product": {
          "type": "string"
        },
        "alias_of": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "beta",
            "wip",
            "deprecated"
          ]
        }
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "name",
    "type"
  ],
  "additionalProperties": false
}
