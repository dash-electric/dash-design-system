{
  "name": "@dash/build",
  "version": "0.1.0-beta.0",
  "description": "Dash Build — Lovable-for-Dash internal builder. Browser-based AI workflow for any Dash team member.",
  "license": "MIT",
  "author": "Dash Tech (PT Dash Elektrik Indonesia)",
  "private": true,
  "type": "module",
  "bin": {
    "dash-build": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dash-tech/dash-build.git"
  },
  "homepage": "https://github.com/dash-tech/dash-build#readme",
  "bugs": {
    "url": "https://github.com/dash-tech/dash-build/issues"
  },
  "files": [
    "dist",
    "preview-template",
    "scripts/probe-sandpack-cdn.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-dash-ui-to-template.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "copy-dash-ui": "node scripts/copy-dash-ui-to-template.mjs",
    "verify:cdn": "node scripts/probe-sandpack-cdn.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm audit:css && pnpm audit:tokens && pnpm verify:cdn && pnpm test && pnpm build",
    "pretest": "pnpm audit:css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "check-bundle-size": "tsx scripts/check-bundle-size.ts",
    "audit": "pnpm audit:css && pnpm audit:tokens",
    "audit:css": "node scripts/audit-css.mjs",
    "audit:css:allowlist": "node scripts/audit-css.mjs --fix-allowlist",
    "audit:css:strict": "node scripts/audit-css.mjs --strict",
    "audit:css:report": "node scripts/audit-css.mjs --report",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "audit:tokens:strict": "node scripts/audit-tokens.mjs --strict",
    "audit:tokens:report": "node scripts/audit-tokens.mjs --report"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@octokit/app": "^15.0.0",
    "@octokit/rest": "^21.0.0",
    "boxen": "^7.1.0",
    "chalk": "^5.4.0",
    "open": "^10.1.0",
    "@dash/skill": "workspace:*",
    "@dash/registry-schema": "workspace:*",
    "@dash/aop-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "esbuild": ">=0.21"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  }
}
