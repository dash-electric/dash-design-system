{
  "name": "@dash/build",
  "version": "0.1.0",
  "description": "Dash Build — Lovable-for-Dash internal builder. Browser-based AI workflow for any Dash team member.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "bin": {
    "dash-build": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "pnpm audit:css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "check-bundle-size": "tsx scripts/check-bundle-size.ts",
    "audit": "pnpm audit:css && pnpm audit:tokens",
    "audit:css": "node scripts/audit-css.mjs",
    "audit:css:allowlist": "node scripts/audit-css.mjs --fix-allowlist",
    "audit:css:strict": "node scripts/audit-css.mjs --strict",
    "audit:css:report": "node scripts/audit-css.mjs --report",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "audit:tokens:strict": "node scripts/audit-tokens.mjs --strict",
    "audit:tokens:report": "node scripts/audit-tokens.mjs --report"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@octokit/app": "^15.0.0",
    "@octokit/rest": "^22.0.1",
    "boxen": "^7.1.0",
    "chalk": "^5.4.0",
    "open": "^11.0.0",
    "@dash/skill": "workspace:*",
    "@dash/registry-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "esbuild": ">=0.21"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  }
}
