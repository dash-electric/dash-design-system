# Dash Build — environment configuration (copy to .env for local dev)

# ── MCP boundary (design-contract reads) ────────────────────────────────────
# The dash-build loaders (design.md / rules / glossary / catalog) read from the
# MCP boundary when DASH_DS_MCP_URL is set, falling back to the monorepo
# filesystem on any error. The real daemon defaults this to the local
# registry/docs server when unset (MCP-boundary Phase 4). Set explicitly to
# point at a remote dash-doc registry after the repo split.
DASH_DS_MCP_URL=http://localhost:3000

# Registry origin used by the CLI + mcp-server (and the DASH_DS_MCP_URL
# fallback default). Production consumer repos export https://ds.dash.com.
# DASH_REGISTRY_URL=http://localhost:3000

# ── Daemon ───────────────────────────────────────────────────────────────────
# DASH_BUILD_PORT=7777
# DASH_BUILD_WORK_ROOT=$HOME/Work/dash      # local checkouts for clone+intake
# DASH_BUILD_CLONE_FROM_LOCAL=1             # clone baseline from local FS, not GitHub
# DASH_BUILD_DEV_SERVER_TIMEOUT_MS=420000   # cold-compile budget for first boot
# DASH_BUILD_WATCH=1                        # dev CSS/template HMR watcher
