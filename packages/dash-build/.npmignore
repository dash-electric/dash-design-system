# Source — only ship the compiled dist/ output (the `files` whitelist in
# package.json is the primary gate, but .npmignore catches dev-only entries
# that slip through pre-publish hooks.).
src/
**/__tests__/**
**/*.test.ts
**/*.test.tsx

# Repo-level dev infra
.git/
.github/
.vscode/
.idea/
node_modules/
.turbo/

# Build / cache
*.log
*.tsbuildinfo
.cache/
coverage/

# Editor cruft
.DS_Store
Thumbs.db

# Internal docs (long-form planning — top-level README.md ships, the rest stay)
docs/
AUDIT-*.md
HANDOFF-*.md
# npm auto-includes README files at every directory level; we only want
# the package-root README.md in the tarball.
scripts/README.md

# Dev configs not needed by consumers
vitest.config.ts
tsconfig.scripts.json
tsup.config.ts
