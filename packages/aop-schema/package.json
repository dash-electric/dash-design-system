{
  "name": "@dash/aop-schema",
  "version": "1.0.0",
  "description": "Agent Observability Protocol (AOP) v1.0.0 schemas, validators, and wire-format helpers. Zero runtime dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js",
      "require": "./dist/schemas.cjs"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "import": "./dist/validators.js",
      "require": "./dist/validators.cjs"
    },
    "./redact": {
      "types": "./dist/redact.d.ts",
      "import": "./dist/redact.js",
      "require": "./dist/redact.cjs"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js",
      "require": "./dist/replay.cjs"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js",
      "require": "./dist/wire.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsup": "^8.3.5",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "dash",
    "aop",
    "agent-observability",
    "schema",
    "validator",
    "jsonl",
    "sse"
  ]
}
