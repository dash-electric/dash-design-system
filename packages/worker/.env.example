# ---------------------------------------------------------------------------
# Hermes worker — environment template.
# Copy to `.env` for local dev. NEVER commit a populated copy.
# ---------------------------------------------------------------------------

# --- Required ---------------------------------------------------------------
# Anthropic API key. Worker refuses to start in non-dry-run mode without it.
ANTHROPIC_API_KEY=

# GitHub PAT (fine-grained recommended; needs `contents:write` + `pulls:write`
# on the target repo). Without it, PR creation is stubbed (logs only).
GITHUB_TOKEN=

# --- Optional (with defaults) -----------------------------------------------
# Target repo for PRs.
GITHUB_REPO=irfanputra-design/dash

# Anthropic model id.
ANTHROPIC_MODEL=claude-opus-4-7

# Slack incoming webhook for outcome notifications. Skipped if blank.
SLACK_WEBHOOK_URL=

# Foundation-score thresholds.
MIN_SCORE_AUTO_MERGE=85
MIN_SCORE_REVIEW=60

# Watch-loop interval (ms). Health endpoint flags "stuck" at 2× this.
POLL_INTERVAL_MS=60000

# Path to checked-out dash-ds repo INSIDE the container/host. Worker writes
# generated blocks under <REGISTRY_ROOT>/apps/docs/registry/dash/blocks/.
REGISTRY_ROOT=/app/dash-ds

# Dashboard API base URL (Dash DS admin UI).
DASH_API_URL=https://ds.dash.com

# CEO/admin token for dashboard API calls (if Hermes posts back outcomes).
DASH_CEO_TOKEN=

# HTTP port for the /health endpoint. Railway/Fly inject their own PORT —
# leave blank in those envs.
PORT=8080
