# Dash Dashboard — environment variables
# Copy to .env.local for dev. Production lives in Railway env settings.

# ---- Required ----

# HMAC key for ingest endpoints (heartbeat, ds-add).
# Tribe apps sign POST body with this key.
INGEST_HMAC_KEY=change-me-min-32-bytes

# ---- Required IF NEXTAUTH_URL is set (i.e. real auth) ----

# Public URL of this app. Unset for local dev to bypass auth.
# Example: https://dashboard.dash.com
# NEXTAUTH_URL=

# Secret for JWT session signing. Generate with `openssl rand -base64 32`.
# NEXTAUTH_SECRET=

# Google OAuth client (Dash workspace).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- Optional — warm store ----

# When unset, uses file-based libSQL at ~/.dash-dashboard/dev.db
# TURSO_URL=libsql://dash-dashboard-prod.turso.io
# TURSO_TOKEN=

# ---- Optional — alerting (Phase 2) ----
# SLACK_WEBHOOK_OPS=
# SLACK_WEBHOOK_LEADERSHIP=
# SLACK_WEBHOOK_ENG=
