{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @dash/dashboard build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @dash/dashboard start",
    "healthcheckPath": "/api/v1/health/tribes",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
