{
  "name": "dash",
  "version": "0.4.0",
  "description": "Dash Design System CLI — install registry items into your project",
  "license": "MIT",
  "author": "Dash Tech (PT Dash Elektrik Indonesia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dash-tech/dash-cli.git"
  },
  "homepage": "https://github.com/dash-tech/dash-cli#readme",
  "bugs": {
    "url": "https://github.com/dash-tech/dash-cli/issues"
  },
  "type": "module",
  "bin": {
    "dash": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dash/registry-schema": "workspace:*",
    "commander": "^12.1.0",
    "detect-package-manager": "^3.0.2",
    "kleur": "^4.1.5",
    "ora": "^9.4.0",
    "postcss": "^8.5.15",
    "postcss-safe-parser": "^7.0.1",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
