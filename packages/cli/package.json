{
  "name": "@dash-electric/dashkit",
  "version": "0.4.1",
  "description": "Dash Design System CLI — install registry items into your project",
  "license": "UNLICENSED",
  "author": "Dash Tech (PT Dash Elektrik Indonesia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dash-electric/next-express-design-system.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/dash-electric/next-express-design-system/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/dash-electric/next-express-design-system/issues"
  },
  "type": "module",
  "bin": {
    "dashkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "detect-package-manager": "^3.0.2",
    "kleur": "^4.1.5",
    "ora": "^9.4.0",
    "postcss": "^8.5.15",
    "postcss-safe-parser": "^7.0.1",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dash/registry-schema": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
